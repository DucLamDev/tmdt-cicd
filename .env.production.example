# Copy this file to /opt/marketplace/.env on the VPS and replace all placeholder values.
# Do not commit real secrets.

# Public domain for Caddy.
# Use a real domain for HTTPS, for example: shop.example.com
# If you only test by server IP without HTTPS, use: :80
APP_DOMAIN=shop.example.com

# Public URLs used by backend redirects, uploads, CORS, and payment callbacks.
FRONTEND_URL=https://shop.example.com
API_URL=https://shop.example.com
CORS_ORIGINS=https://shop.example.com

# Container images. GitHub Actions will also keep these values updated on the VPS.
BACKEND_IMAGE=ghcr.io/OWNER/REPOSITORY/backend:latest
FRONTEND_IMAGE=ghcr.io/OWNER/REPOSITORY/frontend:latest
AI_TRYON_IMAGE=ghcr.io/OWNER/REPOSITORY/ai-tryon:latest

# MongoDB.
MONGO_INITDB_ROOT_USERNAME=marketplace_root
MONGO_INITDB_ROOT_PASSWORD=change-this-mongo-password
MONGODB_URI=mongodb://marketplace_root:change-this-mongo-password@mongo:27017/marketplace?authSource=admin

# Redis.
REDIS_URL=redis://redis:6379

# Backend runtime.
NODE_ENV=production
PORT=5000
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_RESET_PASSWORD_SECRET=change-this-reset-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_RESET_PASSWORD_EXPIRY=1h
RATE_LIMIT_MAX_REQUESTS=10000
API_RATE_LIMIT_MAX_REQUESTS=1200
AUTH_RATE_LIMIT_MAX_REQUESTS=50
PASSWORD_RESET_RATE_LIMIT_MAX_REQUESTS=10
LOG_LEVEL=info
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Backend calls the AI service through Docker network.
AI_TRYON_SERVICE_URL=http://ai-tryon:8000

# Email.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# AI providers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-5.5

# AI try-on service.
HOST=0.0.0.0
TRYON_PROVIDER=opencv
TRYON_STRICT=false
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=jpeg
OPENAI_IMAGE_TIMEOUT=180
REPLICATE_API_TOKEN=
REPLICATE_IDM_ENDPOINT=https://api.replicate.com/v1/models/cuuupid/idm-vton/predictions
REPLICATE_POLL_TIMEOUT=120
LOCAL_TRYON_TIMEOUT=600
PROMPT_IMAGE_TIMEOUT=600

# Payment gateways. Replace sandbox values before production payment.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=https://shop.example.com/payment/vnpay/callback
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=https://shop.example.com/payment/momo/callback
MOMO_IPN_URL=https://shop.example.com/api/payments/momo/ipn
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=https://shop.example.com/api/payments/zalopay/callback
ZALOPAY_RETURN_URL=https://shop.example.com/payment/zalopay/callback

# Shipping.
GHN_BASE_URL=https://online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=
GHN_SHOP_ID=
ADDRESS_SOURCE=modern

