HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
UPLOAD_DIR=./uploads

# openai | replicate | idm-vton | catvton | stable-diffusion | local | prompt-image | opencv
TRYON_PROVIDER=openai

# OpenAI GPT Image provider.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=jpeg
OPENAI_IMAGE_TIMEOUT=180

REPLICATE_API_TOKEN=
REPLICATE_IDM_ENDPOINT=https://api.replicate.com/v1/models/cuuupid/idm-vton/predictions
REPLICATE_POLL_TIMEOUT=120

# Gemini is only used for style/size analysis text and prompt refinement.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Local GPU pipeline hooks.
# Use quoted placeholders: {person}, {garment}, {output}, {category}, {description}
# category is mapped to IDM-VTON values: upper_body, lower_body, dresses.
LOCAL_TRYON_TIMEOUT=600
IDM_VTON_COMMAND=python C:/models/IDM-VTON/inference.py --human {person} --garment {garment} --category {category} --output {output} --garment_des {description}
CATVTON_COMMAND=python C:/models/CatVTON/inference.py --person {person} --cloth {garment} --output {output}
STABLE_DIFFUSION_TRYON_COMMAND=python C:/models/sd-tryon/infer.py --person {person} --cloth {garment} --out {output}

# Prompt-based image generation.
# Gemini writes {prompt} and {negative_prompt}; this command must call your image model
# and save the generated file to {output}. Best used with ComfyUI/SDXL/Flux img2img,
# ControlNet, IP-Adapter, or a Stable Diffusion Try-On workflow.
PROMPT_IMAGE_TIMEOUT=600
PROMPT_IMAGE_COMMAND=python C:/models/tryon-prompt/generate.py --person {person} --garment {garment} --prompt {prompt} --negative {negative_prompt} --output {output}

# Optional preprocessing hooks. If set, these run before the try-on command.
OPENPOSE_COMMAND=
DENSEPOSE_COMMAND=
HUMAN_PARSING_COMMAND=
SAM_COMMAND=
CONTROLNET_COMMAND=

# true: fail instead of falling back to OpenCV when the main provider fails
TRYON_STRICT=false
